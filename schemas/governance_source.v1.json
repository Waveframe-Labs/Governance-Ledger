{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.waveframe.dev/governance_source.v1.json",
  "title": "Governance Source",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "source_version",
    "canonical_text",
    "source_hash"
  ],
  "properties": {
    "schema_version": {
      "const": "governance_source.v1"
    },
    "source_version": {
      "type": "string",
      "minLength": 1
    },
    "canonical_text": {
      "type": "string"
    },
    "source_hash": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    }
  }
}
