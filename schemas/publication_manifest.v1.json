{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.waveframe.dev/publication_manifest.v1.json",
  "title": "Publication Manifest",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "publication_id",
    "published_at",
    "published_by",
    "contracts",
    "reviews",
    "snapshots"
  ],
  "properties": {
    "schema_version": {
      "const": "publication_manifest.v1"
    },
    "publication_id": {
      "type": "string",
      "minLength": 1
    },
    "published_at": {
      "type": "string",
      "minLength": 1
    },
    "published_by": {
      "type": "string",
      "minLength": 1
    },
    "contracts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": [
          "contract_id",
          "contract_version",
          "contract_hash",
          "path"
        ],
        "properties": {
          "contract_id": {
            "type": "string",
            "minLength": 1
          },
          "contract_version": {
            "type": "string",
            "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
          },
          "contract_hash": {
            "type": "string",
            "pattern": "^sha256:[a-f0-9]{64}$"
          },
          "source_hash": {
            "type": "string",
            "pattern": "^sha256:[a-f0-9]{64}$"
          },
          "compilation_report_hash": {
            "type": "string",
            "pattern": "^sha256:[a-f0-9]{64}$"
          },
          "path": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "reviews": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["path"],
        "properties": {
          "path": {
            "type": "string",
            "minLength": 1
          }
        },
        "additionalProperties": true
      }
    },
    "snapshots": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["path"],
        "properties": {
          "path": {
            "type": "string",
            "minLength": 1
          }
        },
        "additionalProperties": true
      }
    }
  }
}
